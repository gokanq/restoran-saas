generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  COURIER
  CUSTOMER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  ON_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderType {
  TABLE
  DELIVERY
  TAKEAWAY
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  ONLINE
  MEAL_CARD
  OPEN_ACCOUNT
}

enum TableSessionStatus {
  OPEN
  PAYMENT_PENDING
  CLOSED
  CANCELLED
}

enum TableSessionItemStatus {
  NEW
  SENT
  PREPARING
  SERVED
  VOID
}

model Restaurant {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  isActive             Boolean               @default(true)
  users                User[]
  branches             Branch[]
  orders               Order[]
  couriers             Courier[]
  courierWorkLogs      CourierWorkLog[]
  menuCategories       MenuCategory[]
  menuItems            MenuItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  menuItemOptionGroups MenuItemOptionGroup[]
  menuItemOptions      MenuItemOption[]
  diningAreas          DiningArea[]
  restaurantTables     RestaurantTable[]
  tableSessions        TableSession[]
}

model Branch {
  id                   String                @id @default(cuid())
  restaurantId         String
  name                 String
  address              String?
  phone                String?
  restaurant           Restaurant            @relation(fields: [restaurantId], references: [id])
  orders               Order[]
  couriers             Courier[]
  menuCategories       MenuCategory[]
  menuItems            MenuItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  menuItemOptionGroups MenuItemOptionGroup[]
  menuItemOptions      MenuItemOption[]
  diningAreas          DiningArea[]
  restaurantTables     RestaurantTable[]
  tableSessions        TableSession[]
}

model DiningArea {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String
  name         String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  branch     Branch          @relation(fields: [branchId], references: [id])
  tables     RestaurantTable[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([isActive])
}

model RestaurantTable {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String
  diningAreaId String?
  code         String
  name         String
  capacity     Int?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id])
  branch     Branch        @relation(fields: [branchId], references: [id])
  diningArea DiningArea?   @relation(fields: [diningAreaId], references: [id])
  sessions   TableSession[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([diningAreaId])
  @@index([isActive])
  @@unique([branchId, code])
}

model TableSession {
  id              String             @id @default(cuid())
  restaurantId    String
  branchId        String
  tableId         String
  status          TableSessionStatus @default(OPEN)
  openedByUserId  String?
  closedByUserId  String?
  cancelledReason String?
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id])
  branch     Branch             @relation(fields: [branchId], references: [id])
  table      RestaurantTable    @relation(fields: [tableId], references: [id])
  items      TableSessionItem[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([tableId])
  @@index([status])
}

model TableSessionItem {
  id          String                 @id @default(cuid())
  sessionId   String
  menuItemId  String?
  name        String
  quantity    Int                    @default(1)
  unitPrice   Decimal                @default(0) @db.Decimal(10, 2)
  totalPrice  Decimal                @default(0) @db.Decimal(10, 2)
  note        String?
  status      TableSessionItemStatus @default(NEW)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  session  TableSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  menuItem  MenuItem?               @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  options   TableSessionItemOption[]

  @@index([sessionId])
  @@index([menuItemId])
  @@index([status])
}

model TableSessionItemOption {
  id          String   @id @default(cuid())
  itemId       String
  optionId    String?
  groupName   String
  optionName  String
  priceDelta  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  item   TableSessionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  option MenuItemOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([optionId])
}

model User {
  id           String      @id @default(cuid())
  restaurantId String?
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(ADMIN)
  isActive     Boolean     @default(true)
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  branchId     String?
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  branch       Branch?    @relation(fields: [branchId], references: [id])
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MenuItem {
  id           String                @id @default(cuid())
  restaurantId String
  branchId     String?
  categoryId   String?
  name         String
  description  String?
  price        Decimal               @default(0) @db.Decimal(10, 2)
  isActive     Boolean               @default(true)
  restaurant   Restaurant            @relation(fields: [restaurantId], references: [id])
  branch       Branch?               @relation(fields: [branchId], references: [id])
  category     MenuCategory?         @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  optionGroups MenuItemOptionGroup[]
  tableSessionItems TableSessionItem[]
}

model Courier {
  id            String     @id @default(cuid())
  restaurantId  String
  branchId      String?
  name          String
  phone         String?
  perPackageFee Decimal    @default(0) @db.Decimal(10, 2)
  hourlyFee     Decimal    @default(0) @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  branch        Branch?    @relation(fields: [branchId], references: [id])
  orders        Order[]
  workLogs      CourierWorkLog[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([restaurantId])
  @@index([branchId])
  @@index([isActive])
}

model CourierWorkLog {
  id           String     @id @default(cuid())
  restaurantId String
  courierId    String
  workDate     DateTime   @db.Date
  hours        Decimal    @default(0) @db.Decimal(10, 2)
  note         String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  courier      Courier    @relation(fields: [courierId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, courierId, workDate])
  @@index([restaurantId, workDate])
  @@index([courierId])
}

model Order {
  id              String      @id @default(cuid())
  restaurantId    String
  branchId        String
  code            String
  type            OrderType   @default(DELIVERY)
  tableNumber     String?
  status          OrderStatus @default(PENDING)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @default(CASH)
  customerName    String?
  customerPhone   String?
  customerAddress String?
  courierId       String?
  courierName     String?
  note            String?
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  branch          Branch      @relation(fields: [branchId], references: [id])
  courier         Courier?    @relation(fields: [courierId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([courierId])
}

model OrderItem {
  id         String            @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String
  quantity   Int               @default(1)
  unitPrice  Decimal           @default(0) @db.Decimal(10, 2)
  totalPrice Decimal           @default(0) @db.Decimal(10, 2)
  note       String?
  order      Order             @relation(fields: [orderId], references: [id])
  menuItem   MenuItem?         @relation(fields: [menuItemId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  options    OrderItemOption[]
}

model MenuItemOptionGroup {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String?
  menuItemId   String
  name         String
  isRequired   Boolean  @default(false)
  minSelect    Int      @default(0)
  maxSelect    Int      @default(1)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id])
  branch     Branch?          @relation(fields: [branchId], references: [id])
  menuItem   MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options    MenuItemOption[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([menuItemId])
}

model MenuItemOption {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String?
  groupId      String
  name         String
  priceDelta   Decimal  @default(0)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id])
  branch           Branch?             @relation(fields: [branchId], references: [id])
  group            MenuItemOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]
  tableSessionItemOptions TableSessionItemOption[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([groupId])
}

model OrderItemOption {
  id          String   @id @default(cuid())
  orderItemId String
  optionId    String?
  groupName   String
  optionName  String
  priceDelta  Decimal  @default(0)
  createdAt   DateTime @default(now())

  orderItem OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    MenuItemOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([optionId])
}
